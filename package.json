{
  "name": "sunchaser",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "template": {
    "name": "sunchaser",
    "displayName": "Sunchaser",
    "description": "Collaborative summer trip planner on Microsoft Fabric Apps + Rayfin — groups, destination voting, availability overlap, and a live dashboard"
  },
  "scripts": {
    "predev": "rayfin env --framework vite",
    "prebuild": "rayfin env --framework vite",
    "dev": "rayfin up --exclude-services staticHosting && vite",
    "demo": "vite --mode demo",
    "build": "tsc -b && vite build",
    "build:fabric": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "rayfin:up": "rayfin up",
    "rayfin:db": "rayfin up db apply",
    "shots": "node scripts/shoot-app.mjs && node scripts/shoot-landing.mjs"
  },
  "dependencies": {
    "@microsoft/rayfin-auth-provider-fabric": "^1.33.2",
    "@microsoft/rayfin-client": "^1.33.2",
    "@microsoft/rayfin-core": "^1.33.2",
    "@microsoft/rayfin-data": "^1.33.2",
    "@tailwindcss/vite": "^4.1.11",
    "d3-geo": "^3.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@microsoft/rayfin-cli": "^1.33.2",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^24.1.0",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
